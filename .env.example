# Required in production — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# Port the server listens on (default: 3000)
PORT=3000

# Host the server binds to (default: 127.0.0.1 — localhost only, recommended behind a reverse proxy)
# Set to 0.0.0.0 only if you have a specific reason to expose the port directly
HOST=127.0.0.1

# Set to "production" in production deployments
NODE_ENV=production
